# Test environment variables.
# Loaded by tests via ENV_FILE=tests/env/test.env (see app.config.get_settings).

# Telegram (dummy value, no real bot needed for tests)
TELEGRAM_TOKEN=test-token

# Polymarket API credentials (dummy values; clients hit the public read-only APIs)
POLYMARKET_API_KEY=test-key
POLYMARKET_API_SECRET=test-secret
POLYMARKET_API_PASSPHRASE=test-pass
POLYMARKET_ADDRESS=0x0000000000000000000000000000000000000000

# Test database (matches docker-compose service)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=betting_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=betting_bot
